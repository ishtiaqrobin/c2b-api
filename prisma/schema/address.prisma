model Address {
    id     String      @id @default(cuid())
    userId String
    type   AddressType @default(HOME)
    label  String? // optional friendly name

    recipientName   String?
    telephone       String?
    postCode        String
    districtId      Int
    cityTownVillage String
    streetAddress   String
    apartment       String?

    isDefault Boolean   @default(false)
    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    district District @relation(fields: [districtId], references: [id])
    orders   Order[]

    @@index([userId])
    @@index([districtId])
    @@map("address")
}

model Division {
    id     Int    @id @default(autoincrement())
    code   String @unique // e.g. BD-1
    nameEn String
    nameBn String

    districts District[]

    @@map("division")
}

model District {
    id         Int    @id @default(autoincrement())
    code       String @unique // e.g. BD-DHA
    nameEn     String
    nameBn     String
    divisionId Int

    division            Division             @relation(fields: [divisionId], references: [id])
    addresses           Address[]
    individualProfiles  IndividualProfile[]
    corpCompanyProfiles CorporationProfile[] @relation("CorpCompanyDistrict")
    corpContactProfiles CorporationProfile[] @relation("CorpContactDistrict")

    @@index([divisionId])
    @@map("district")
}
