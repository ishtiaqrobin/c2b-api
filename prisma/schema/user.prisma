model IndividualProfile {
    id     String @id @default(cuid())
    userId String @unique

    qualifiedInvoiceStatus QualifiedInvoiceStatus @default(NOT_APPLICABLE)

    fullName    String
    telephone   String
    dateOfBirth DateTime
    sex         Sex
    occupation  OccupationType @default(OTHERS)

    postCode        String
    districtId      Int
    cityTownVillage String
    streetAddress   String
    apartment       String?

    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    district District @relation(fields: [districtId], references: [id])

    @@index([districtId])
    @@map("individual_profile")
}

model CorporationProfile {
    id     String @id @default(cuid())
    userId String @unique

    qualifiedInvoiceStatus String

    // Company Information
    companyName            String
    companyTelephone       String
    companyPostCode        String
    companyDistrictId      Int
    companyCityTownVillage String
    companyStreetAddress   String
    companyApartment       String?

    // Person in charge information
    contactName        String
    contactTelephone   String
    contactDateOfBirth DateTime
    contactSex         Sex

    contactOccupation OccupationType @default(OTHERS)
    contactPostCode   String
    contactDistrictId Int

    contactCityTownVillage String
    contactStreetAddress   String
    contactApartment       String?

    // Bank account
    bankAccount       String
    bankAccountBranch String
    bankAccountType   BankAccountType
    bankAccountName   String
    bankAccountNumber String

    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    companyDistrict District @relation("CorpCompanyDistrict", fields: [companyDistrictId], references: [id])
    contactDistrict District @relation("CorpContactDistrict", fields: [contactDistrictId], references: [id])

    @@index([companyDistrictId])
    @@index([contactDistrictId])
    @@map("corporation_profile")
}
