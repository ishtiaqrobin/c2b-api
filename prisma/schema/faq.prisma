model Faq {
    id        String   @id @default(cuid())
    question  String
    answer    String
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    isDeleted Boolean  @default(false)
    deletedAt DateTime?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("faq")
}
