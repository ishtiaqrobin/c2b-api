model News {
    id          String    @id @default(cuid())
    title       String
    body        String?
    publishedAt DateTime  @default(now())
    isActive    Boolean   @default(true)
    isDeleted   Boolean   @default(false)
    deletedAt   DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([publishedAt])
    @@map("news")
}
