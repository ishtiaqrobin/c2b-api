model Cart {
    id        String   @id @default(cuid())
    userId    String?
    sessionId String?  @unique // guest token, merged on login
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
    items CartItem[]

    @@index([userId])
    @@map("cart")
}

model CartItem {
    id        String        @id @default(cuid())
    cartId    String
    variantId String
    condition ItemCondition
    quantity  Int           @default(1)
    notes     String?
    expiresAt DateTime // 30-min expiry per item
    createdAt DateTime      @default(now())

    cart       Cart                @relation(fields: [cartId], references: [id], onDelete: Cascade)
    variant    ProductVariant      @relation(fields: [variantId], references: [id])
    deductions CartItemDeduction[]

    @@index([cartId])
    @@index([expiresAt])
    @@map("cart_item")
}

model CartItemDeduction {
    id          String @id @default(cuid())
    cartItemId  String
    deductionId String

    cartItem  CartItem         @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
    deduction VariantDeduction @relation(fields: [deductionId], references: [id])

    @@unique([cartItemId, deductionId])
    @@map("cart_item_deduction")
}
