model Order {
    id          String        @id @default(cuid())
    orderNumber String        @unique // e.g. BB-2026-000123
    userId      String
    method      BuybackMethod
    status      OrderStatus   @default(PENDING)

    // In-store
    storeId String?

    // Staff member currently responsible for processing this order.
    // Lets a Store Manager filter "my store's orders by staff" and
    // distinguishes ownership from the audit-trail-only OrderStatusHistory.changedBy.
    handledBy String?

    // Mail-in
    courier           Courier?
    trackingNumber    String?
    shippingAddressId String?

    totalAmount Decimal @default(0) @db.Decimal(12, 2)
    currency    String  @default("JPY")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user            User                 @relation(fields: [userId], references: [id])
    store           Store?               @relation(fields: [storeId], references: [id])
    shippingAddress Address?             @relation(fields: [shippingAddressId], references: [id])
    items           OrderItem[]
    statusHistory   OrderStatusHistory[]
    payment         Payment?
    adminTasks      AdminTask[]

    @@index([userId])
    @@index([status])
    @@index([storeId])
    @@index([handledBy])
    @@map("order")
}

model OrderItem {
    id        String        @id @default(cuid())
    orderId   String
    variantId String
    condition ItemCondition
    quantity  Int           @default(1)
    notes     String?

    // Price snapshot at order creation
    basePriceSnapshot   Decimal @db.Decimal(12, 2)
    totalDeduction      Decimal @default(0) @db.Decimal(12, 2)
    unitPriceSnapshot   Decimal @db.Decimal(12, 2)
    lineTotal           Decimal @db.Decimal(12, 2)
    productNameSnapshot String

    order      Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
    variant    ProductVariant       @relation(fields: [variantId], references: [id])
    deductions OrderItemDeduction[]
    stockItem  StockItem?

    @@index([orderId])
    @@map("order_item")
}

model OrderItemDeduction {
    id          String @id @default(cuid())
    orderItemId String
    deductionId String

    labelSnapshot  String
    amountSnapshot Decimal @db.Decimal(12, 2)

    orderItem OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
    deduction VariantDeduction @relation(fields: [deductionId], references: [id])

    @@map("order_item_deduction")
}

model OrderStatusHistory {
    id        String      @id @default(cuid())
    orderId   String
    status    OrderStatus
    note      String?
    changedBy String?
    createdAt DateTime    @default(now())

    order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@index([orderId])
    @@map("order_status_history")
}
