model Product {
    id            String    @id @default(cuid())
    slug          String    @unique
    categoryId    String
    imageUrl      String?
    imagePublicId String?
    updateDate    DateTime  @default(now())
    isActive      Boolean   @default(true)
    isDeleted     Boolean   @default(false)
    deletedAt     DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    category     Category             @relation(fields: [categoryId], references: [id])
    translations ProductTranslation[]
    variants     ProductVariant[]

    @@index([categoryId])
    @@map("product")
}

model ProductTranslation {
    id        String @id @default(cuid())
    productId String
    locale    Locale
    name      String

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([productId, locale])
    @@map("product_translation")
}

model ProductVariant {
    id        String  @id @default(cuid())
    productId String
    sku       String? @unique

    storage String?
    color   String?

    // Global buyback prices (live reference for cart)
    newPrice  Decimal? @db.Decimal(12, 2)
    usedPrice Decimal? @db.Decimal(12, 2)
    currency  String   @default("JPY")

    // Purchase limits (null = unlimited)
    maxQuantityPerOrder Int?
    dailyPurchaseLimit  Int?

    isActive  Boolean   @default(true)
    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
    deductions   VariantDeduction[]
    cartItems    CartItem[]
    orderItems   OrderItem[]
    priceHistory PriceHistory[]
    stockItems   StockItem[]

    @@index([productId])
    @@index([storage])
    @@map("product_variant")
}

// Flexible/dynamic deductions, condition-tagged
model VariantDeduction {
    id        String        @id @default(cuid())
    variantId String
    condition ItemCondition
    amount    Decimal       @db.Decimal(12, 2)
    sortOrder Int           @default(0)
    isActive  Boolean       @default(true)
    isDeleted Boolean       @default(false)
    deletedAt DateTime?
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt

    variant             ProductVariant                @relation(fields: [variantId], references: [id], onDelete: Cascade)
    translations        VariantDeductionTranslation[]
    cartItemSelections  CartItemDeduction[]
    orderItemSelections OrderItemDeduction[]

    @@index([variantId, condition])
    @@map("variant_deduction")
}

model VariantDeductionTranslation {
    id          String @id @default(cuid())
    deductionId String
    locale      Locale
    label       String // e.g. "Opened", "No box"

    deduction VariantDeduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)

    @@unique([deductionId, locale])
    @@map("variant_deduction_translation")
}

// Price change audit trail
model PriceHistory {
    id        String        @id @default(cuid())
    variantId String
    condition ItemCondition
    oldPrice  Decimal?      @db.Decimal(12, 2)
    newPrice  Decimal       @db.Decimal(12, 2)
    changedBy String? // user id of admin/owner
    createdAt DateTime      @default(now())

    variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

    @@index([variantId])
    @@index([createdAt])
    @@map("price_history")
}
