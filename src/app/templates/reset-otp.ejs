<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C2B Password Reset</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f7f9;
            color: #333;
        }

        .container {
            max-width: 600px;
            margin: 20px auto;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }

        .header {
            background-color: #3b82f6;
            /* Blue for Reset/Security actions */
            padding: 30px;
            text-align: center;
            color: white;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .content {
            padding: 40px 30px;
            text-align: center;
        }

        .greeting {
            font-size: 18px;
            color: #1f2937;
            margin-bottom: 20px;
        }

        .otp-box {
            background-color: #eff6ff;
            border: 2px dashed #3b82f6;
            padding: 20px;
            margin: 30px auto;
            display: inline-block;
            border-radius: 8px;
        }

        .otp-code {
            font-size: 36px;
            font-weight: 800;
            letter-spacing: 8px;
            color: #1d4ed8;
            margin: 0;
        }

        .expiry-text {
            color: #6b7280;
            font-size: 14px;
            margin-top: 15px;
        }

        .footer {
            background-color: #f9fafb;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            border-top: 1px solid #e5e7eb;
        }

        .warning {
            color: #ef4444;
            font-size: 13px;
            margin-top: 25px;
            font-style: italic;
        }

        @media only screen and (max-width: 600px) {
            .container {
                margin: 0;
                border-radius: 0;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>C2B</h1>
        </div>
        <div class="content">
            <p class="greeting">Hello, <strong>
                    <%= name %>
                </strong>!</p>
            <p>We received a request to reset your password. Please use the following One-Time Password (OTP) to
                proceed:</p>

            <div class="otp-box">
                <p class="otp-code">
                    <%= otp %>
                </p>
            </div>

            <p class="expiry-text">This OTP is valid for <strong>2 minutes</strong>.</p>

            <p class="warning">If you did not request a password reset, please ignore this email. Your password will
                remain unchanged.</p>
        </div>
        <div class="footer">
            <p>&copy; 2024 C2B. All rights reserved.</p>
            <p>Your security is our priority.</p>
        </div>
    </div>
</body>

</html>